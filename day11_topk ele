class Solution:
    def topKFrequent(self, nums: List[int], k: int) -> List[int]:
        d={}
        for i in nums:
            if i not in d:
                d[i]=1
            else:
                d[i]+=1
        sorted_nums=sorted(d,key=d.get,reverse=True)
          
        return sorted_nums[:k]